{
  "title": "StreamForge",
  "uid": "streamforge",
  "schemaVersion": 39,
  "datasource": { "type": "prometheus", "uid": "prometheus" },
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "5s",
  "panels": [
    {
      "title": "Throughput (events/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(streamforge_events_consumed_total[30s]))", "legendFormat": "consumed/s" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(streamforge_records_emitted_total[30s]))", "legendFormat": "emitted/s" }
      ]
    },
    {
      "title": "Event latency (event_time -> aggregation)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.50, sum by (le) (rate(streamforge_event_latency_seconds_bucket[1m])))", "legendFormat": "p50" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum by (le) (rate(streamforge_event_latency_seconds_bucket[1m])))", "legendFormat": "p95" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum by (le) (rate(streamforge_event_latency_seconds_bucket[1m])))", "legendFormat": "p99" }
      ]
    },
    {
      "title": "Checkpoint duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.50, sum by (le) (rate(streamforge_checkpoint_duration_seconds_bucket[2m])))", "legendFormat": "p50" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum by (le) (rate(streamforge_checkpoint_duration_seconds_bucket[2m])))", "legendFormat": "p99" }
      ]
    },
    {
      "title": "Last completed checkpoint",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(streamforge_last_completed_checkpoint)" }]
    },
    {
      "title": "Shuffle bytes/sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(streamforge_shuffle_bytes_total[30s]))", "legendFormat": "shuffle B/s" }]
    }
  ]
}
